<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AtsEmployeeStats.Maui.Views.CompanyDetailPage"
             Title="{Binding Title}"
             BackgroundColor="{AppThemeBinding Light=#F6F7F9, Dark=#15171A}">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                <VerticalStackLayout Spacing="3">
                    <Label Text="{Binding Title}" FontSize="28" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#20242A, Dark=#F2F4F7}" />
                    <Label Text="{Binding Subtitle}" FontSize="13" TextColor="{AppThemeBinding Light=#6A737D, Dark=#AAB2BD}" />
                    <Label Text="{Binding StatusText}" FontSize="13" TextColor="{AppThemeBinding Light=#5B6470, Dark=#B5BDC7}" />
                </VerticalStackLayout>
                <ActivityIndicator Grid.Column="1" IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
            </Grid>

            <FlexLayout BindableLayout.ItemsSource="{Binding Metrics}" Wrap="Wrap" Direction="Row" AlignItems="Stretch">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Border Stroke="{AppThemeBinding Light=#D9DEE6, Dark=#303640}" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#20242A}" Padding="14" Margin="0,0,10,10" MinimumWidthRequest="132">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="{Binding Value}" FontSize="18" FontAttributes="Bold" />
                                <Label Text="{Binding Label}" FontSize="12" TextColor="{AppThemeBinding Light=#6A737D, Dark=#AAB2BD}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </FlexLayout>

            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Sections}" Spacing="14">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Border Stroke="{AppThemeBinding Light=#D9DEE6, Dark=#303640}" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#20242A}" Padding="16">
                            <VerticalStackLayout Spacing="10">
                                <Label Text="{Binding Title}" FontSize="18" FontAttributes="Bold" />
                                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Rows}" Spacing="8">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="1.3*,*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12">
                                                <Label Text="{Binding Name}" FontAttributes="Bold" />
                                                <Label Grid.Column="1" Text="{Binding PrimaryText}" />
                                                <Label Grid.Column="2" Text="{Binding MetaText}" TextColor="{AppThemeBinding Light=#6A737D, Dark=#AAB2BD}" />
                                                <Label Grid.Row="1" Grid.ColumnSpan="3" Text="{Binding SecondaryText}" FontSize="12" TextColor="{AppThemeBinding Light=#6A737D, Dark=#AAB2BD}" />
                                            </Grid>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
