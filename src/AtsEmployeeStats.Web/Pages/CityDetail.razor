@page "/companies/{CompanyId}/cities/{CityId}"
@inherits AtsEmployeeStats.Web.Pages.DashboardBase

<main class="dashboard-shell">
    <section class="topbar">
        <div>
            <h1>@(SelectedCity?.DisplayName ?? "City")</h1>
            <p>@Status</p>
        </div>
        <div class="day-range" role="group" aria-label="Game day range">
            <label>Days <input type="number" min="0" value="@FromDay" @onchange="SetFromDayAsync" /> – <input type="number" min="0" value="@ToDay" @onchange="SetToDayAsync" /></label>

        </div>
    </section>

    <nav class="breadcrumb" aria-label="Current location">
        <NavLink href="/">Companies</NavLink>
        @if (SelectedCompany is not null)
        {
            <NavLink href="@($"/companies/{Segment(SelectedCompany.Id)}")">@SelectedCompany.DisplayName</NavLink>
        }
        @if (SelectedCity is not null)
        {
            <span>@SelectedCity.DisplayName</span>
        }
    </nav>

    @if (Statistics is null)
    {
        <div class="empty-state">Loading city...</div>
    }
    else if (SelectedCompany is null)
    {
        <div class="empty-state"><p>Company not found.</p><NavLink class="button-link" href="/">Back to companies</NavLink></div>
    }
    else if (SelectedCity is null)
    {
        <div class="empty-state"><p>City not found.</p><NavLink class="button-link" href="@($"/companies/{Segment(SelectedCompany.Id)}")">Back to company</NavLink></div>
    }
    else
    {
        <section class="detail-summary">
            <div><span>Visits</span><strong>@SelectedCity.VisitCount</strong></div>
            <div><span>Outbound</span><strong>@Money(SelectedCity.OutboundProfit)</strong></div>
            <div><span>Inbound</span><strong>@Money(SelectedCity.InboundProfit)</strong></div>
            <div><span>Expansion</span><strong>@SelectedCity.ExpansionScore</strong></div>
        </section>

        <nav class="tabs" aria-label="City detail sections">
            <button class="@TabClass("details")" @onclick="@(() => _activeTab = "details")">Details</button>
            <button class="@TabClass("routes")" @onclick="@(() => _activeTab = "routes")">Routes</button>
            <button class="@TabClass("jobs")" @onclick="@(() => _activeTab = "jobs")">Jobs</button>
            <button class="@TabClass("trailers")" @onclick="@(() => _activeTab = "trailers")">Trailer Types</button>
            <button class="@TabClass("profitability")" @onclick="@(() => _activeTab = "profitability")">Profitability</button>
            <button class="@TabClass("expansion")" @onclick="@(() => _activeTab = "expansion")">Expansion Potential</button>
        </nav>

        <section class="content-stack">
            @if (_activeTab == "routes")
            {
                <table>
                    <caption>Routes - @SelectedCity.DisplayName</caption>
                    <thead>
                        <tr>
                            <th>Route</th>
                            <SortableColumnHeader Column="profit" ActiveColumn="@_routesSortBy" Descending="@_routesSortDesc" OnSort="SortRoutesAsync">Profit</SortableColumnHeader>
                            <SortableColumnHeader Column="jobCount" ActiveColumn="@_routesSortBy" Descending="@_routesSortDesc" OnSort="SortRoutesAsync">Jobs</SortableColumnHeader>
                            <SortableColumnHeader Column="profitPerMile" ActiveColumn="@_routesSortBy" Descending="@_routesSortDesc" OnSort="SortRoutesAsync">$/mile</SortableColumnHeader>
                            <SortableColumnHeader Column="returnCoverage" ActiveColumn="@_routesSortBy" Descending="@_routesSortDesc" OnSort="SortRoutesAsync">Return coverage</SortableColumnHeader>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var route in DashboardViewModel.GetCityRoutes(SelectedCompany, SelectedCity.Id))
                        {
                            <tr>
                                <td>@route.OriginCityId -&gt; @route.DestinationCityId</td>
                                <td>@Money(route.Profit)</td>
                                <td>@route.JobCount</td>
                                <td>@route.ProfitPerMile.ToString("F2")</td>
                                <td>@route.ReturnCoverageRatio</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else if (_activeTab == "jobs")
            {
                <table>
                    <caption>Jobs - @SelectedCity.DisplayName</caption>
                    <thead>
                        <tr>
                            <th></th>
                            <th>Route</th>
                            <th>Cargo</th>
                            <SortableColumnHeader Column="profit" ActiveColumn="@_missionsSortBy" Descending="@_missionsSortDesc" OnSort="SortMissionsAsync">Profit</SortableColumnHeader>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var job in DashboardViewModel.GetCityJobs(SelectedCompany, SelectedCity.Id))
                        {
                            <tr>
                                <td class="action-cell"><NavLink class="button-link" href="@($"/companies/{Segment(SelectedCompany.Id)}/jobs/{Segment(job.Id)}")">View</NavLink></td>
                                <td>@(job.SourceCity ?? "?") -&gt; @(job.TargetCity ?? "?")</td>
                                <td>@(job.Cargo ?? "-")</td>
                                <td>@Money(job.Profit)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else if (_activeTab == "trailers")
            {
                <TrailerTypePieChart Items="@DashboardViewModel.GetCityTrailerTypeBreakdown(SelectedCompany, SelectedCity.Id)" />
            }
            else
            {
                <table>
                    <caption>@(_activeTab == "expansion" ? "Expansion Potential" : _activeTab == "profitability" ? "Profitability" : "Details")</caption>
                    <thead><tr><th>Metric</th><th>Value</th></tr></thead>
                    <tbody>
                        <tr><td>Owned garage</td><td>@(SelectedCity.HasOwnedGarage ? "Yes" : "No")</td></tr>
                        <tr><td>Garage eligible</td><td>@(SelectedCity.IsGarageEligible ? "Yes" : "No")</td></tr>
                        <tr><td>Bidirectional profit</td><td>@Money(SelectedCity.BidirectionalProfit)</td></tr>
                        <tr><td>Expansion score</td><td>@SelectedCity.ExpansionScore</td></tr>
                    </tbody>
                </table>
            }
        </section>
    }
</main>

@code {
    [Parameter] public string CompanyId { get; set; } = string.Empty;
    [Parameter] public string CityId { get; set; } = string.Empty;

    private string _activeTab = "details";

    private string _routesSortBy = "profit";
    private bool _routesSortDesc = true;
    private string _missionsSortBy = "profit";
    private bool _missionsSortDesc = true;

    private CompanyDto? SelectedCompany => DashboardViewModel.FindCompany(Statistics, CompanyId);
    private CityDto? SelectedCity => SelectedCompany is null ? null : DashboardViewModel.FindCity(SelectedCompany, CityId);
    private string TabClass(string tab) => _activeTab == tab ? "active" : string.Empty;

    private async Task SortRoutesAsync((string Column, bool Descending) sort)
    {
        (_routesSortBy, _routesSortDesc) = sort;
        await SetCollectionSortAsync(CollectionSort with { RoutesSortBy = _routesSortBy, RoutesSortDir = _routesSortDesc ? null : "asc" });
    }

    private async Task SortMissionsAsync((string Column, bool Descending) sort)
    {
        (_missionsSortBy, _missionsSortDesc) = sort;
        await SetCollectionSortAsync(CollectionSort with { MissionsSortBy = _missionsSortBy, MissionsSortDir = _missionsSortDesc ? null : "asc" });
    }
}
