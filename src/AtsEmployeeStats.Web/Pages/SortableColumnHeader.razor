<th title="@Title">
    <button class="sort-header @(IsActive ? (Descending ? "sort-desc" : "sort-asc") : string.Empty)"
            type="button"
            @onclick="HandleClick">
        @ChildContent
        @if (IsActive)
        {
            <span aria-hidden="true">@(Descending ? " ↓" : " ↑")</span>
        }
    </button>
</th>

@code {
    [Parameter, EditorRequired] public string Column { get; set; } = "";
    [Parameter, EditorRequired] public string ActiveColumn { get; set; } = "";
    [Parameter] public bool Descending { get; set; } = true;
    [Parameter] public EventCallback<(string Column, bool Descending)> OnSort { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Title { get; set; }

    private bool IsActive => string.Equals(Column, ActiveColumn, StringComparison.OrdinalIgnoreCase);

    private Task HandleClick()
    {
        var nextDesc = IsActive ? !Descending : true;
        return OnSort.InvokeAsync((Column, nextDesc));
    }
}
