@page "/companies/{CompanyId}/trucks/{TruckId}"
@inherits AtsEmployeeStats.Web.Pages.DashboardBase

<main class="dashboard-shell">
    <section class="topbar">
        <div>
            <h1>@(SelectedTruck?.DisplayName ?? "Truck")</h1>
            <p>@Status</p>
        </div>
        <div class="day-range" role="group" aria-label="Game day range">
            <label>Days <input type="number" min="0" value="@FromDay" @onchange="SetFromDayAsync" /> – <input type="number" min="0" value="@ToDay" @onchange="SetToDayAsync" /></label>

        </div>
    </section>

    <nav class="breadcrumb" aria-label="Current location">
        <NavLink href="/">Companies</NavLink>
        @if (SelectedCompany is not null)
        {
            <NavLink href="@($"/companies/{Segment(SelectedCompany.Id)}")">@SelectedCompany.DisplayName</NavLink>
        }
        @if (SelectedTruck is not null)
        {
            <span>@SelectedTruck.DisplayName</span>
        }
    </nav>

    @if (Statistics is null)
    {
        <div class="empty-state">Loading truck...</div>
    }
    else if (SelectedCompany is null)
    {
        <div class="empty-state"><p>Company not found.</p><NavLink class="button-link" href="/">Back to companies</NavLink></div>
    }
    else if (SelectedTruck is null)
    {
        <div class="empty-state"><p>Truck not found.</p><NavLink class="button-link" href="@($"/companies/{Segment(SelectedCompany.Id)}")">Back to company</NavLink></div>
    }
    else
    {
        <section class="detail-summary">
            <div><span>Profit</span><strong>@Money(SelectedTruck.Profit)</strong></div>
            <div><span>Garage</span><strong>@(SelectedTruck.GarageId ?? "-")</strong></div>
            <div><span>Driver</span><strong>@(SelectedTruck.DriverId ?? "-")</strong></div>
            <div><span>Plate</span><strong>@(SelectedTruck.LicensePlate ?? "-")</strong></div>
        </section>

        <nav class="tabs" aria-label="Truck detail sections">
            <button class="@TabClass("details")" @onclick="@(() => _activeTab = "details")">Details</button>
            <button class="@TabClass("jobs")" @onclick="@(() => _activeTab = "jobs")">Jobs</button>
            <button class="@TabClass("trailers")" @onclick="@(() => _activeTab = "trailers")">Trailers</button>
        </nav>

        <section class="content-stack">
            @if (_activeTab == "jobs")
            {
                <table>
                    <caption>Jobs - @SelectedTruck.DisplayName</caption>
                    <thead>
                        <tr>
                            <th></th>
                            <th>Route</th>
                            <th>Cargo</th>
                            <th>Trailer</th>
                            <SortableColumnHeader Column="profit" ActiveColumn="@_missionsSortBy" Descending="@_missionsSortDesc" OnSort="SortMissionsAsync">Profit</SortableColumnHeader>
                            <SortableColumnHeader Column="day" ActiveColumn="@_missionsSortBy" Descending="@_missionsSortDesc" OnSort="SortMissionsAsync">Day</SortableColumnHeader>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var job in DashboardViewModel.GetTruckJobs(SelectedCompany, SelectedTruck.Id))
                        {
                            <tr>
                                <td class="action-cell"><NavLink class="button-link" href="@($"/companies/{Segment(SelectedCompany.Id)}/jobs/{Segment(job.Id)}")">View</NavLink></td>
                                <td>@(job.SourceCity ?? "?") -&gt; @(job.TargetCity ?? "?")</td>
                                <td>@(job.Cargo ?? "-")</td>
                                <td>@(job.TrailerId ?? job.TrailerType ?? "-")</td>
                                <td>@Money(job.Profit)</td>
                                <td>@(job.TimestampDay?.ToString() ?? "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else if (_activeTab == "trailers")
            {
                <table>
                    <caption>Trailers</caption>
                    <thead><tr><th></th><th>Trailer</th><th>Type</th></tr></thead>
                    <tbody>
                        @foreach (var trailer in (SelectedCompany.Trailers ?? []).Where(trailer => DashboardViewModel.GetTrailerJobs(SelectedCompany, trailer.Id).Any(job => job.TruckId == SelectedTruck.Id)))
                        {
                            <tr>
                                <td class="action-cell"><NavLink class="button-link" href="@($"/companies/{Segment(SelectedCompany.Id)}/trailers/{Segment(trailer.Id)}")">View</NavLink></td>
                                <td>@trailer.Id</td>
                                <td>@trailer.TrailerType</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <table>
                    <caption>Details</caption>
                    <thead><tr><th>Field</th><th>Value</th></tr></thead>
                    <tbody>
                        <tr><td>Truck id</td><td>@SelectedTruck.Id</td></tr>
                        <tr><td>Model</td><td>@(SelectedTruck.ModelName ?? "-")</td></tr>
                        <tr><td>Definition</td><td>@(SelectedTruck.DefinitionPath ?? "-")</td></tr>
                    </tbody>
                </table>
            }
        </section>
    }
</main>

@code {
    [Parameter] public string CompanyId { get; set; } = string.Empty;
    [Parameter] public string TruckId { get; set; } = string.Empty;

    private string _activeTab = "details";

    private string _missionsSortBy = "profit";
    private bool _missionsSortDesc = true;

    private CompanyDto? SelectedCompany => DashboardViewModel.FindCompany(Statistics, CompanyId);
    private TruckDto? SelectedTruck => SelectedCompany is null ? null : DashboardViewModel.FindTruck(SelectedCompany, TruckId);
    private string TabClass(string tab) => _activeTab == tab ? "active" : string.Empty;

    private async Task SortMissionsAsync((string Column, bool Descending) sort)
    {
        (_missionsSortBy, _missionsSortDesc) = sort;
        await SetCollectionSortAsync(CollectionSort with { MissionsSortBy = _missionsSortBy, MissionsSortDir = _missionsSortDesc ? null : "asc" });
    }
}
