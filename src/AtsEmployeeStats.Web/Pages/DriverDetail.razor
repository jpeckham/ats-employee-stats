@page "/companies/{CompanyId}/drivers/{DriverId}"
@page "/companies/{CompanyId}/garages/{GarageId}/drivers/{DriverId}"
@inherits AtsEmployeeStats.Web.Pages.DashboardBase

<main class="dashboard-shell">
    <section class="topbar">
        <div>
            <h1>@(SelectedDriver?.DisplayName ?? "Driver")</h1>
            <p>@Status</p>
        </div>
        <div class="day-range" role="group" aria-label="Game day range">
            <label>Days <input type="number" min="0" value="@FromDay" @onchange="SetFromDayAsync" /> – <input type="number" min="0" value="@ToDay" @onchange="SetToDayAsync" /></label>

        </div>
    </section>

    @if (Progress is not null)
    {
        <section class="progress-strip" aria-label="Save loading progress">
            <div>
                <span>Save files</span>
                <strong>@FileProgressText</strong>
                <progress max="@FileProgressMax" value="@FileProgressValue"></progress>
            </div>
            <div>
                <span>Current save</span>
                <strong>@CurrentSaveProgressText</strong>
                <progress max="@CurrentSaveProgressMax" value="@CurrentSaveProgressValue"></progress>
            </div>
        </section>
    }

    <nav class="breadcrumb" aria-label="Current location">
        <NavLink href="/">Companies</NavLink>
        @if (SelectedCompany is not null)
        {
            <NavLink href="@($"/companies/{Segment(SelectedCompany.Id)}")">@SelectedCompany.DisplayName</NavLink>
        }
        @if (SelectedCompany is not null && SelectedGarage is not null)
        {
            <NavLink href="@($"/companies/{Segment(SelectedCompany.Id)}/garages/{Segment(SelectedGarage.Id)}")">@SelectedGarage.DisplayName</NavLink>
        }
        @if (SelectedDriver is not null)
        {
            <span>@SelectedDriver.DisplayName</span>
        }
    </nav>

    @if (Statistics is null)
    {
        <div class="empty-state">Loading driver...</div>
    }
    else if (SelectedCompany is null)
    {
        <div class="empty-state">
            <p>Company not found.</p>
            <NavLink class="button-link" href="/">Back to companies</NavLink>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(GarageId) && SelectedGarage is null)
    {
        <div class="empty-state">
            <p>Garage not found.</p>
            <NavLink class="button-link" href="@($"/companies/{Segment(SelectedCompany.Id)}")">Back to company</NavLink>
        </div>
    }
    else if (SelectedDriver is null)
    {
        <div class="empty-state">
            <p>Driver not found.</p>
            <NavLink class="button-link" href="@ParentHref">Back</NavLink>
        </div>
    }
    else
    {
        <section class="detail-summary">
            <div>
                <span>Profit</span>
                <strong>@Money(SelectedDriver.Profit)</strong>
            </div>
            <div>
                <span>$/Day</span>
                <strong>@Money(SelectedDriver.ProfitPerDay)</strong>
            </div>
            <div>
                <span>Jobs</span>
                <strong>@SelectedDriver.JobCount</strong>
            </div>
            <div>
                <span>Current truck</span>
                <strong>@DashboardViewModel.GetTruckDisplayName(SelectedCompany, SelectedDriver.TruckId)</strong>
            </div>
        </section>

        <nav class="tabs" aria-label="Driver detail sections">
            <button class="@TabClass("jobs")" @onclick="@(() => _activeTab = "jobs")">Jobs</button>
            <button class="@TabClass("trucks")" @onclick="@(() => _activeTab = "trucks")">Trucks</button>
            <button class="@TabClass("garages")" @onclick="@(() => _activeTab = "garages")">Garages</button>
        </nav>

        <section class="content-stack">
            @if (_activeTab == "jobs")
            {
                var recentJobs = DashboardViewModel.GetDriverRecentJobs(SelectedCompany, SelectedDriver.Id);
                if (recentJobs.Count > 0)
                {
                    <table>
                        <caption>Recent jobs - @SelectedDriver.DisplayName</caption>
                        <thead>
                            <tr><th>Route</th><th>Cargo</th><th>Truck</th><th>Distance</th><th>Profit</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var job in recentJobs)
                            {
                                <tr>
                                    <td>@(job.SourceCity ?? "?") -&gt; @(job.TargetCity ?? "?")</td>
                                    <td>@(job.Cargo ?? "-")</td>
                                    <td>@DashboardViewModel.GetTruckDisplayName(SelectedCompany, job.TruckId)</td>
                                    <td>@Distance(job.Distance)</td>
                                    <td>@Money(job.Profit)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }

                <table>
                    <caption>Jobs - @SelectedDriver.DisplayName</caption>
                    <thead>
                        <tr>
                            <th>Route</th>
                            <th>Cargo</th>
                            <th>Trailer</th>
                            <th>Truck</th>
                            <SortableColumnHeader Column="profit" ActiveColumn="@_missionsSortBy" Descending="@_missionsSortDesc" OnSort="SortMissionsAsync">Profit</SortableColumnHeader>
                            <SortableColumnHeader Column="day" ActiveColumn="@_missionsSortBy" Descending="@_missionsSortDesc" OnSort="SortMissionsAsync">Day</SortableColumnHeader>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var mission in DashboardViewModel.GetDriverJobs(SelectedCompany, SelectedDriver.Id))
                        {
                            <tr>
                                <td>@(mission.SourceCity ?? "?") -&gt; @(mission.TargetCity ?? "?")</td>
                                <td>@(mission.Cargo ?? "-")</td>
                                <td>@(mission.TrailerType ?? "-")</td>
                                <td>@DashboardViewModel.GetTruckDisplayName(SelectedCompany, mission.TruckId)</td>
                                <td>@Money(mission.Profit)</td>
                                <td>@(mission.TimestampDay?.ToString() ?? "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else if (_activeTab == "trucks")
            {
                var driverTrucks = DashboardViewModel.GetDriverTrucks(SelectedCompany, SelectedDriver.Id);
                var truckHistory = DashboardViewModel.GetDriverTruckAssignments(SelectedCompany, SelectedDriver.Id);
                <table>
                    <caption>Trucks - @SelectedDriver.DisplayName</caption>
                    <thead>
                        <tr><th></th><th>Truck</th><th>Profit</th><th>Garage</th><th>Current driver</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var truck in driverTrucks)
                        {
                            <tr>
                                <td class="action-cell">
                                    <NavLink class="button-link" href="@($"/companies/{Segment(SelectedCompany.Id)}/trucks/{Segment(truck.Id)}")">View</NavLink>
                                </td>
                                <td>@truck.DisplayName</td>
                                <td>@Money(truck.Profit)</td>
                                <td>@DashboardViewModel.GetGarageDisplayName(SelectedCompany, truck.GarageId)</td>
                                <td>@DashboardViewModel.GetDriverDisplayName(SelectedCompany, truck.DriverId)</td>
                            </tr>
                        }
                    </tbody>
                </table>
                @if (truckHistory.Count > 0)
                {
                    <table>
                        <caption>Truck assignment history - @SelectedDriver.DisplayName</caption>
                        <thead>
                            <tr><th>Truck</th><th>From save</th><th>To save</th><th>Current</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var a in truckHistory)
                            {
                                <tr>
                                    <td>@DashboardViewModel.GetTruckDisplayName(SelectedCompany, a.TruckId)</td>
                                    <td>@a.EffectiveFromSaveName</td>
                                    <td>@(a.EffectiveToSaveName ?? "-")</td>
                                    <td>@(a.IsCurrent ? "Yes" : "No")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            }
            else if (_activeTab == "garages")
            {
                var garageHistory = DashboardViewModel.GetDriverGarageAssignments(SelectedCompany, SelectedDriver.Id);
                @if (garageHistory.Count > 0)
                {
                    <table>
                        <caption>Garage assignment history - @SelectedDriver.DisplayName</caption>
                        <thead>
                            <tr><th>Garage</th><th>From save</th><th>To save</th><th>Current</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var a in garageHistory)
                            {
                                <tr>
                                    <td>@DashboardViewModel.GetGarageDisplayName(SelectedCompany, a.GarageId)</td>
                                    <td>@a.EffectiveFromSaveName</td>
                                    <td>@(a.EffectiveToSaveName ?? "-")</td>
                                    <td>@(a.IsCurrent ? "Yes" : "No")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="empty-state">No garage assignment history recorded.</p>
                }
            }
        </section>
    }
</main>

@code {
    [Parameter]
    public string CompanyId { get; set; } = string.Empty;

    [Parameter]
    public string? GarageId { get; set; }

    [Parameter]
    public string DriverId { get; set; } = string.Empty;

    private string _activeTab = "jobs";

    private string _missionsSortBy = "profit";
    private bool _missionsSortDesc = true;

    private CompanyDto? SelectedCompany =>
        DashboardViewModel.FindCompany(Statistics, CompanyId);

    private GarageDto? SelectedGarage =>
        SelectedCompany is null || string.IsNullOrWhiteSpace(GarageId)
            ? null
            : DashboardViewModel.FindGarage(SelectedCompany, GarageId);

    private DriverDto? SelectedDriver =>
        SelectedCompany is null ? null : DashboardViewModel.FindDriver(SelectedCompany, DriverId);

    private string ParentHref =>
        SelectedCompany is null
            ? "/"
            : SelectedGarage is null
                ? $"/companies/{Segment(SelectedCompany.Id)}"
                : $"/companies/{Segment(SelectedCompany.Id)}/garages/{Segment(SelectedGarage.Id)}";

    private string TabClass(string tab) =>
        _activeTab == tab ? "active" : string.Empty;

    private async Task SortMissionsAsync((string Column, bool Descending) sort)
    {
        (_missionsSortBy, _missionsSortDesc) = sort;
        await SetCollectionSortAsync(CollectionSort with { MissionsSortBy = _missionsSortBy, MissionsSortDir = _missionsSortDesc ? null : "asc" });
    }

    private static string Distance(int? miles) =>
        miles is null ? "-" : $"{miles:N0} mi";
}
