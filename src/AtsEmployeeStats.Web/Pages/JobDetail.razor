@page "/companies/{CompanyId}/jobs/{JobId}"
@inherits AtsEmployeeStats.Web.Pages.DashboardBase

<main class="dashboard-shell">
    <section class="topbar">
        <div>
            <h1>@(SelectedJob?.Cargo ?? "Job")</h1>
            <p>@Status</p>
        </div>
        <div class="day-range" role="group" aria-label="Game day range">
            <label>Days <input type="number" min="0" value="@FromDay" @onchange="SetFromDayAsync" /> – <input type="number" min="0" value="@ToDay" @onchange="SetToDayAsync" /></label>

        </div>
    </section>

    <nav class="breadcrumb" aria-label="Current location">
        <NavLink href="/">Companies</NavLink>
        @if (SelectedCompany is not null)
        {
            <NavLink href="@($"/companies/{Segment(SelectedCompany.Id)}")">@SelectedCompany.DisplayName</NavLink>
        }
        @if (SelectedJob is not null)
        {
            <span>@(SelectedJob.Cargo ?? SelectedJob.Id)</span>
        }
    </nav>

    @if (Statistics is null)
    {
        <div class="empty-state">Loading job...</div>
    }
    else if (SelectedCompany is null)
    {
        <div class="empty-state"><p>Company not found.</p><NavLink class="button-link" href="/">Back to companies</NavLink></div>
    }
    else if (SelectedJob is null)
    {
        <div class="empty-state"><p>Job not found.</p><NavLink class="button-link" href="@($"/companies/{Segment(SelectedCompany.Id)}")">Back to company</NavLink></div>
    }
    else
    {
        <section class="detail-summary">
            <div><span>Profit</span><strong>@Money(SelectedJob.Profit)</strong></div>
            <div><span>Route</span><strong>@(SelectedJob.SourceCity ?? "?") -&gt; @(SelectedJob.TargetCity ?? "?")</strong></div>
            <div><span>Truck</span><strong>@DashboardViewModel.GetTruckDisplayName(SelectedCompany, SelectedJob.TruckId)</strong></div>
            <div><span>Trailer</span><strong>@(SelectedJob.TrailerId ?? SelectedJob.TrailerType ?? "-")</strong></div>
        </section>

        <nav class="tabs" aria-label="Job detail sections">
            <button class="@TabClass("details")" @onclick="@(() => _activeTab = "details")">Details</button>
            <button class="@TabClass("route")" @onclick="@(() => _activeTab = "route")">Route</button>
            <button class="@TabClass("assets")" @onclick="@(() => _activeTab = "assets")">Truck/Trailer</button>
            <button class="@TabClass("profitability")" @onclick="@(() => _activeTab = "profitability")">Profitability</button>
        </nav>

        <section class="content-stack">
            @if (_activeTab == "route")
            {
                <table>
                    <caption>Route</caption>
                    <thead><tr><th>Origin</th><th>Destination</th><th>Observed profit</th><th>Jobs</th></tr></thead>
                    <tbody>
                        @if (SelectedJob.SourceCity is not null && SelectedJob.TargetCity is not null)
                        {
                            var route = DashboardViewModel.FindRoute(SelectedCompany, SelectedJob.SourceCity, SelectedJob.TargetCity);
                            <tr>
                                <td>@SelectedJob.SourceCity</td>
                                <td>@SelectedJob.TargetCity</td>
                                <td>@Money(route?.Profit ?? SelectedJob.Profit)</td>
                                <td>@(route?.JobCount ?? 1)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else if (_activeTab == "assets")
            {
                <table>
                    <caption>Assets</caption>
                    <thead><tr><th></th><th>Type</th><th>Value</th></tr></thead>
                    <tbody>
                        <tr>
                            <td class="action-cell">@if (SelectedJob.DriverId is not null) { <NavLink class="button-link" href="@($"/companies/{Segment(SelectedCompany.Id)}/drivers/{Segment(SelectedJob.DriverId)}")">View</NavLink> }</td>
                            <td>Driver</td>
                            <td>@(SelectedJob.DriverId ?? "-")</td>
                        </tr>
                        <tr>
                            <td class="action-cell">@if (SelectedJob.TruckId is not null) { <NavLink class="button-link" href="@($"/companies/{Segment(SelectedCompany.Id)}/trucks/{Segment(SelectedJob.TruckId)}")">View</NavLink> }</td>
                            <td>Truck</td>
                            <td>@DashboardViewModel.GetTruckDisplayName(SelectedCompany, SelectedJob.TruckId)</td>
                        </tr>
                        <tr>
                            <td class="action-cell">@if (SelectedJob.TrailerId is not null) { <NavLink class="button-link" href="@($"/companies/{Segment(SelectedCompany.Id)}/trailers/{Segment(SelectedJob.TrailerId)}")">View</NavLink> }</td>
                            <td>Trailer</td>
                            <td>@(SelectedJob.TrailerId ?? SelectedJob.TrailerType ?? "-")</td>
                        </tr>
                    </tbody>
                </table>
            }
            else
            {
                <table>
                    <caption>@(_activeTab == "profitability" ? "Profitability" : "Details")</caption>
                    <thead><tr><th>Field</th><th>Value</th></tr></thead>
                    <tbody>
                        <tr><td>Job id</td><td>@SelectedJob.Id</td></tr>
                        <tr><td>Cargo</td><td>@(SelectedJob.Cargo ?? "-")</td></tr>
                        <tr><td>Trailer type</td><td>@(SelectedJob.TrailerType ?? "-")</td></tr>
                        <tr><td>Game day</td><td>@(SelectedJob.TimestampDay?.ToString() ?? "-")</td></tr>
                        <tr><td>Profit</td><td>@Money(SelectedJob.Profit)</td></tr>
                    </tbody>
                </table>
            }
        </section>
    }
</main>

@code {
    [Parameter] public string CompanyId { get; set; } = string.Empty;
    [Parameter] public string JobId { get; set; } = string.Empty;

    private string _activeTab = "details";

    private CompanyDto? SelectedCompany => DashboardViewModel.FindCompany(Statistics, CompanyId);
    private MissionDto? SelectedJob => SelectedCompany is null ? null : DashboardViewModel.FindJob(SelectedCompany, JobId);
    private string TabClass(string tab) => _activeTab == tab ? "active" : string.Empty;
}
