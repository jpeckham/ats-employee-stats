@using AtsEmployeeStats.Web.Services

@if (Items.Count == 0)
{
    <p class="muted">No trailer type data for this city.</p>
}
else
{
    <div class="pie-chart-layout">
        <svg viewBox="0 0 200 200" width="180" height="180" aria-hidden="true">
            @{
                var total = Items.Sum(x => (double)x.Profit);
                if (Items.Count == 1)
                {
                    <circle cx="100" cy="100" r="90" fill="@SliceColor(0)" />
                }
                else
                {
                    double startDeg = -90;
                    for (int i = 0; i < Items.Count; i++)
                    {
                        double sweep = Items[i].Profit / total * 360;
                        <path d="@SlicePath(100, 100, 90, startDeg, startDeg + sweep)" fill="@SliceColor(i)" />
                        startDeg += sweep;
                    }
                }
            }
        </svg>
        <ul class="pie-legend">
            @for (int i = 0; i < Items.Count; i++)
            {
                var item = Items[i];
                var color = SliceColor(i);
                <li>
                    <span class="legend-swatch" style="background:@color"></span>
                    <span class="legend-label">@item.TrailerType</span>
                    <span class="legend-profit">@FormatMoney(item.Profit)</span>
                </li>
            }
        </ul>
    </div>
}

@code {
    [Parameter, EditorRequired]
    public IReadOnlyList<TrailerTypeProfitItem> Items { get; set; } = [];

    private static readonly string[] Colors =
    [
        "#1f7a68", "#e07b39", "#6b54a0", "#d4a017",
        "#c04e4e", "#4e7bc0", "#5e9e5e", "#4a9e8e"
    ];

    private static string SliceColor(int index) => Colors[index % Colors.Length];

    private static string SlicePath(double cx, double cy, double r, double startDeg, double endDeg)
    {
        var s = startDeg * Math.PI / 180;
        var e = endDeg * Math.PI / 180;
        var x1 = cx + r * Math.Cos(s);
        var y1 = cy + r * Math.Sin(s);
        var x2 = cx + r * Math.Cos(e);
        var y2 = cy + r * Math.Sin(e);
        var large = (endDeg - startDeg) > 180 ? 1 : 0;
        return $"M {cx} {cy} L {x1:F2} {y1:F2} A {r} {r} 0 {large} 1 {x2:F2} {y2:F2} Z";
    }

    private static string FormatMoney(long value) =>
        value >= 0
            ? $"${value / 100:N0}.{value % 100:D2}"
            : $"-${Math.Abs(value) / 100:N0}.{Math.Abs(value) % 100:D2}";
}
