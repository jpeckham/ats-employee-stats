<Window x:Class="AtsEmployeeStats.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AtsEmployeeStats.Wpf.Controls"
        xmlns:viewModels="clr-namespace:AtsEmployeeStats.Wpf.ViewModels"
        Title="ATS Employee Stats"
        Width="1500"
        Height="900"
        MinWidth="1100"
        MinHeight="680"
        Background="#F4F6F8">
    <Window.Resources>
        <HierarchicalDataTemplate DataType="{x:Type viewModels:ExplorerNodeViewModel}"
                                  ItemsSource="{Binding Children}">
            <TextBlock Text="{Binding Name}"
                       Padding="2"
                       TextTrimming="CharacterEllipsis" />
        </HierarchicalDataTemplate>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top"
                Background="#1F2937"
                Padding="12,8">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal">
                    <Button Content="Refresh"
                            Command="{Binding RefreshCommand}"
                            Width="88"
                            Margin="0,0,8,0" />
                    <Button Content="Reload Saves"
                            Command="{Binding ReloadCommand}"
                            Width="112" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="ATS Employee Stats"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="#CBD5E1"
                               FontSize="12" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#FFFFFF"
                    BorderBrush="#CBD5E1"
                    BorderThickness="0,0,1,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Explorer"
                               FontWeight="SemiBold"
                               Padding="12,10"
                               Background="#EEF2F7" />
                    <TreeView ItemsSource="{Binding Explorer.Roots}"
                              SelectedItemChanged="Explorer_SelectedItemChanged"
                              BorderThickness="0"
                              Padding="6" />
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1"
                          HorizontalAlignment="Stretch"
                          Background="#CBD5E1" />

            <Grid Grid.Column="2"
                  Margin="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid DataContext="{Binding SelectedDetail}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding Subtitle}"
                                   Foreground="#64748B"
                                   FontSize="12" />
                        <TextBlock Text="{Binding Title}"
                                   Foreground="#111827"
                                   FontSize="26"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               Text="{Binding ProfitText}"
                               Foreground="#111827"
                               FontSize="24"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </Grid>

                <ItemsControl Grid.Row="1"
                              ItemsSource="{Binding SelectedDetail.Metrics}"
                              Margin="0,12,0,12">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#CBD5E1"
                                    BorderThickness="1"
                                    Background="White"
                                    Padding="10,7"
                                    Margin="0,0,8,8"
                                    MinWidth="120">
                                <StackPanel>
                                    <TextBlock Text="{Binding Value}"
                                               FontWeight="SemiBold"
                                               Foreground="#111827" />
                                    <TextBlock Text="{Binding Label}"
                                               Foreground="#64748B"
                                               FontSize="11" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TabControl Grid.Row="2"
                            ItemsSource="{Binding SelectedDetail.Tabs}"
                            SelectedIndex="{Binding SelectedDetail.SelectedTabIndex, Mode=OneWay}">
                    <TabControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Title}" />
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                    <TabControl.ContentTemplate>
                        <DataTemplate>
                            <Grid>
                                <controls:OverviewPageControl>
                                    <controls:OverviewPageControl.Style>
                                        <Style TargetType="{x:Type controls:OverviewPageControl}">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOverview}"
                                                             Value="True">
                                                    <Setter Property="Visibility"
                                                            Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </controls:OverviewPageControl.Style>
                                </controls:OverviewPageControl>

                                <DataGrid ItemsSource="{Binding Rows}"
                                          AutoGenerateColumns="False"
                                          CanUserSortColumns="True"
                                          CanUserResizeColumns="True"
                                          IsReadOnly="True"
                                          DataContextChanged="DetailGrid_DataContextChanged"
                                          Loaded="DetailGrid_Loaded"
                                          MouseDoubleClick="DetailGrid_MouseDoubleClick"
                                          GridLinesVisibility="Horizontal"
                                          HeadersVisibility="Column"
                                          RowHeight="28"
                                          AlternatingRowBackground="#F8FAFC"
                                          Background="White"
                                          BorderBrush="#CBD5E1"
                                          BorderThickness="1"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          VirtualizingPanel.VirtualizationMode="Recycling">
                                    <DataGrid.Style>
                                        <Style TargetType="{x:Type DataGrid}">
                                            <Setter Property="Visibility"
                                                    Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOverview}"
                                                             Value="True">
                                                    <Setter Property="Visibility"
                                                            Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.Style>
                                </DataGrid>
                            </Grid>
                        </DataTemplate>
                    </TabControl.ContentTemplate>
                </TabControl>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
