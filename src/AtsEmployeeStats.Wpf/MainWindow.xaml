<Window x:Class="AtsEmployeeStats.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AtsEmployeeStats.Wpf.Controls"
        xmlns:viewModels="clr-namespace:AtsEmployeeStats.Wpf.ViewModels"
        Title="ATS Employee Stats"
        Width="1500"
        Height="900"
        MinWidth="1100"
        MinHeight="680"
        Background="#F4F6F8">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <HierarchicalDataTemplate DataType="{x:Type viewModels:ExplorerNodeViewModel}"
                                  ItemsSource="{Binding Children}">
            <TextBlock Text="{Binding Name}"
                       Padding="2"
                       TextTrimming="CharacterEllipsis" />
        </HierarchicalDataTemplate>
        <Style TargetType="{x:Type TreeViewItem}">
            <Setter Property="IsExpanded"
                    Value="{Binding IsExpanded, Mode=TwoWay}" />
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top"
                Background="#1F2937"
                Padding="12,8">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal">
                    <CheckBox IsChecked="{Binding ExcludePlayerDriver}"
                              Content="Exclude player character"
                              Foreground="White"
                              VerticalAlignment="Center"
                              Margin="0,0,14,0" />
                    <Button Content="Refresh"
                            Command="{Binding RefreshCommand}"
                            IsEnabled="{Binding CanRefreshDashboard}"
                            Width="88"
                            Margin="0,0,8,0" />
                    <Button Content="Manage Sources"
                            Command="{Binding ManageSourcesCommand}"
                            Width="128"
                            Margin="0,0,8,0" />
                    <Button Content="Reload Saves"
                            Command="{Binding ReloadCommand}"
                            IsEnabled="{Binding CanReloadSaves}"
                            Width="112" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="ATS Employee Stats"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="#CBD5E1"
                               FontSize="12" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#FFFFFF"
                    BorderBrush="#CBD5E1"
                    BorderThickness="0,0,1,0"
                    Visibility="{Binding IsExplorerVisible, Converter={StaticResource BoolToVisibility}}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Explorer"
                               FontWeight="SemiBold"
                               Foreground="#111827"
                               Padding="12,10"
                               Background="#EEF2F7" />
                    <TreeView ItemsSource="{Binding Explorer.Roots}"
                              SelectedItemChanged="Explorer_SelectedItemChanged"
                              BorderThickness="0"
                              Padding="6" />
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1"
                          HorizontalAlignment="Stretch"
                          Background="#CBD5E1" />

            <Grid Grid.Column="2"
                  Margin="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.RowSpan="3"
                        Background="White"
                        BorderBrush="#CBD5E1"
                        BorderThickness="1"
                        Padding="28"
                        Visibility="{Binding IsEmptyStateVisible, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel MaxWidth="560"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock Text="No save sources configured"
                                   Foreground="#111827"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center" />
                        <TextBlock Text="Set up ATS and ETS2 save locations before importing save data. The setup wizard will search Steam, Documents, and Steam Cloud profile folders, then let you choose what to include."
                                   Foreground="#64748B"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Margin="0,10,0,18" />
                        <Button Content="Set Up Sources"
                                Command="{Binding ManageSourcesCommand}"
                                Width="150"
                                Height="34"
                                HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

                <Grid DataContext="{Binding SelectedDetail}"
                      Visibility="{Binding DataContext.IsExplorerVisible, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding Subtitle}"
                                   Foreground="#64748B"
                                   FontSize="12" />
                        <TextBlock Text="{Binding Title}"
                                   Foreground="#111827"
                                   FontSize="26"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               Text="{Binding ProfitText}"
                               Foreground="#111827"
                               FontSize="24"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </Grid>

                <ItemsControl Grid.Row="1"
                              ItemsSource="{Binding SelectedDetail.Metrics}"
                              Margin="0,12,0,12">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#CBD5E1"
                                    BorderThickness="1"
                                    Background="White"
                                    Padding="10,7"
                                    Margin="0,0,8,8"
                                    MinWidth="120">
                                <StackPanel>
                                    <TextBlock Text="{Binding Value}"
                                               FontWeight="SemiBold"
                                               Foreground="#111827" />
                                    <TextBlock Text="{Binding Label}"
                                               Foreground="#64748B"
                                               FontSize="11" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TabControl Grid.Row="2"
                            ItemsSource="{Binding SelectedDetail.Tabs}"
                            SelectedIndex="{Binding SelectedDetail.SelectedTabIndex, Mode=OneWay}"
                            SelectionChanged="DetailTabControl_SelectionChanged">
                    <TabControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Title}" />
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                    <TabControl.ContentTemplate>
                        <DataTemplate>
                            <Grid>
                                <controls:OverviewPageControl>
                                    <controls:OverviewPageControl.Style>
                                        <Style TargetType="{x:Type controls:OverviewPageControl}">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOverview}"
                                                             Value="True">
                                                    <Setter Property="Visibility"
                                                            Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </controls:OverviewPageControl.Style>
                                </controls:OverviewPageControl>

                                <DataGrid ItemsSource="{Binding Rows}"
                                          AutoGenerateColumns="False"
                                          CanUserSortColumns="True"
                                          CanUserResizeColumns="True"
                                          IsReadOnly="True"
                                          DataContextChanged="DetailGrid_DataContextChanged"
                                          Loaded="DetailGrid_Loaded"
                                          MouseDoubleClick="DetailGrid_MouseDoubleClick"
                                          GridLinesVisibility="Horizontal"
                                          HeadersVisibility="Column"
                                          RowHeight="28"
                                          AlternatingRowBackground="#F8FAFC"
                                          Background="White"
                                          BorderBrush="#CBD5E1"
                                          BorderThickness="1"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          VirtualizingPanel.VirtualizationMode="Recycling">
                                    <DataGrid.Style>
                                        <Style TargetType="{x:Type DataGrid}">
                                            <Setter Property="Visibility"
                                                    Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOverview}"
                                                             Value="True">
                                                    <Setter Property="Visibility"
                                                            Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.Style>
                                </DataGrid>
                            </Grid>
                        </DataTemplate>
                    </TabControl.ContentTemplate>
                </TabControl>
            </Grid>

            <Border Grid.ColumnSpan="3"
                    Panel.ZIndex="15"
                    Background="#990F172A"
                    Visibility="{Binding IsLoadProgressVisible, Converter={StaticResource BoolToVisibility}}">
                <Border Width="560"
                        Padding="24"
                        Background="White"
                        BorderBrush="#CBD5E1"
                        BorderThickness="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="Reloading saves"
                                   Foreground="#111827"
                                   FontSize="22"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="#64748B"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,18" />
                        <TextBlock Text="{Binding SaveFileProgressText}"
                                   FontWeight="SemiBold"
                                   Foreground="#111827" />
                        <ProgressBar Value="{Binding SaveFileProgressValue, Mode=OneWay}"
                                     Minimum="0"
                                     Maximum="100"
                                     Height="14"
                                     Margin="0,8,0,14" />
                        <TextBlock Text="{Binding SaveContentProgressText}"
                                   Foreground="#64748B"
                                   FontSize="12" />
                        <ProgressBar Value="{Binding SaveContentProgressValue, Mode=OneWay}"
                                     Minimum="0"
                                     Maximum="100"
                                     Height="10"
                                     Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </Border>

            <Border Grid.ColumnSpan="3"
                    Panel.ZIndex="20"
                    Background="#990F172A"
                    Visibility="{Binding IsSourceWizardVisible, Converter={StaticResource BoolToVisibility}}">
                <Border Width="840"
                        MaxHeight="720"
                        Padding="22"
                        Background="White"
                        BorderBrush="#CBD5E1"
                        BorderThickness="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Grid DataContext="{Binding CurrentWizardGame}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <DockPanel>
                            <TextBlock DockPanel.Dock="Right"
                                       Text="{Binding DataContext.SourceWizardStepText, RelativeSource={RelativeSource AncestorType=Window}}"
                                       Foreground="#64748B"
                                       VerticalAlignment="Center" />
                            <StackPanel>
                                <TextBlock Text="Game Source Setup"
                                           Foreground="#111827"
                                           FontSize="22"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="Choose which game saves should be imported into the statistics database."
                                           Foreground="#64748B"
                                           FontSize="12" />
                            </StackPanel>
                        </DockPanel>

                        <CheckBox Grid.Row="1"
                                  IsChecked="{Binding HasGame}"
                                  Margin="0,18,0,12"
                                  FontWeight="SemiBold">
                            <TextBlock>
                                <Run Text="Do you have " />
                                <Run Text="{Binding FullGameName, Mode=OneWay}" />
                                <Run Text="?" />
                            </TextBlock>
                        </CheckBox>

                        <ScrollViewer Grid.Row="2"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Install folders found"
                                           FontWeight="SemiBold"
                                           Foreground="#111827"
                                           Margin="0,0,0,6" />
                                <ItemsControl ItemsSource="{Binding InstallCandidates}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#CBD5E1"
                                                    BorderThickness="1"
                                                    Padding="8"
                                                    Margin="0,0,0,6">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <RadioButton IsChecked="{Binding IsSelected}"
                                                                 GroupName="InstallCandidates"
                                                                 VerticalAlignment="Center"
                                                                 Margin="0,0,8,0" />
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding Path}"
                                                                   Foreground="#111827"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding ProofText}"
                                                                   Foreground="#64748B"
                                                                   FontSize="12" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="Save locations found"
                                           FontWeight="SemiBold"
                                           Foreground="#111827"
                                           Margin="0,14,0,6" />
                                <ItemsControl ItemsSource="{Binding SaveRootCandidates}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#CBD5E1"
                                                    BorderThickness="1"
                                                    Padding="8"
                                                    Margin="0,0,0,6">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox IsChecked="{Binding IsSelected}"
                                                              VerticalAlignment="Center"
                                                              Margin="0,0,8,0" />
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding Path}"
                                                                   Foreground="#111827"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding ProofText}"
                                                                   Foreground="#64748B"
                                                                   FontSize="12" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding SaveFileCount, StringFormat={}{0:N0} saves}"
                                                               Foreground="#111827"
                                                               VerticalAlignment="Center"
                                                               Margin="12,0,0,0" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>

                        <DockPanel Grid.Row="3"
                                   Margin="0,18,0,0">
                            <StackPanel DockPanel.Dock="Right"
                                        Orientation="Horizontal">
                                <Button Content="Back"
                                        Command="{Binding DataContext.PreviousSourceWizardStepCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        Width="86"
                                        Margin="0,0,8,0" />
                                <Button Content="Next"
                                        Command="{Binding DataContext.NextSourceWizardStepCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        Width="86"
                                        Margin="0,0,8,0" />
                                <Button Content="Finish"
                                        Command="{Binding DataContext.FinishSourceWizardCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        Width="96" />
                            </StackPanel>
                        </DockPanel>
                    </Grid>
                </Border>
            </Border>
        </Grid>
    </DockPanel>
</Window>
