<UserControl x:Class="AtsEmployeeStats.Wpf.Controls.OverviewHeaderControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="#FFFFFF"
            BorderBrush="#CBD5E1"
            BorderThickness="1"
            Padding="14"
            Margin="0,0,0,12">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="{Binding Header.Subtitle}"
                           Foreground="#64748B"
                           FontSize="12" />
                <TextBlock Text="{Binding Header.Title}"
                           Foreground="#111827"
                           FontSize="22"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
            <TextBlock Grid.Column="1"
                       Text="{Binding Header.PrimaryValue}"
                       Foreground="#111827"
                       FontSize="22"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />
        </Grid>
    </Border>
</UserControl>
