<UserControl x:Class="AtsEmployeeStats.Wpf.Controls.TrendChartControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">
    <ItemsControl ItemsSource="{Binding TrendCharts}">
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <UniformGrid Columns="2" />
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <Border Background="#FFFFFF"
                        BorderBrush="#CBD5E1"
                        BorderThickness="1"
                        Padding="12"
                        Margin="0,0,10,10"
                        MinHeight="230">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top"
                                   Text="{Binding Title}"
                                   Foreground="#111827"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8" />
                        <lvc:CartesianChart Series="{Binding Series}"
                                            XAxes="{Binding XAxes}"
                                            YAxes="{Binding YAxes}"
                                            LegendPosition="Hidden" />
                    </DockPanel>
                </Border>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>
