<UserControl x:Class="AtsEmployeeStats.Wpf.Controls.OverviewPageControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:AtsEmployeeStats.Wpf.Controls">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
            <controls:OverviewHeaderControl DataContext="{Binding Overview}" />
            <controls:SummaryCardsControl DataContext="{Binding Overview}" />
            <controls:TrendChartControl DataContext="{Binding Overview}" />
            <controls:TopListControl DataContext="{Binding Overview}" />
            <controls:RecentActivityControl DataContext="{Binding Overview}" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
